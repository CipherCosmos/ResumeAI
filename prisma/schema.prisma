generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String           @id @default(cuid())
  email         String?          @unique
  password      String?
  name          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  address       String?
  credits       Int              @default(10)
  emailVerified DateTime?
  image         String?
  phone         String?
  accounts      Account[]
  atsScores     AtsScore[]
  applications  JobApplication[]
  jobMatches    JobMatch[]
  resumes       Resume[]
  sessions      Session[]
  transactions  Transaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

model Resume {
  id             String           @id @default(cuid())
  userId         String
  title          String           @default("My Resume")
  data           Json
  markdown       String?
  vector         Unsupported("vector(768)")?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  atsScores      AtsScore[]
  JobApplication JobApplication[]
  jobMatches     JobMatch[]
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

model AtsScore {
  id          String   @id @default(cuid())
  resumeId    String
  userId      String
  score       Int
  jdSnippet   String?
  matched     Json?
  missing     Json?
  suggestions Json?
  fullResult  Json?
  createdAt   DateTime @default(now())
  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

model JobPosting {
  id              String           @id @default(cuid())
  externalId      String?          @unique
  source          String
  sourceUrl       String?
  title           String
  company         String
  location        String?
  locationType    String?
  description     String
  descriptionRaw  String?
  salary          String?
  salaryMin       Int?
  salaryMax       Int?
  currency        String?          @default("USD")
  skills          Json?
  experienceLevel String?
  employmentType  String?
  industry        String?
  postedAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean          @default(true)
  firstSeen       DateTime         @default(now())
  lastSeen        DateTime         @default(now())
  contentHash     String?
  vector          Unsupported("vector(768)")?
  canonicalJobId  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  applications    JobApplication[]
  matches         JobMatch[]
  versions        JobVersion[]     @relation("JobVersions")
  canonicalJob    JobPosting?      @relation("CanonicalJob", fields: [canonicalJobId], references: [id])
  duplicates      JobPosting[]     @relation("CanonicalJob")

  @@index([title])
  @@index([company])
  @@index([isActive, postedAt(sort: Desc)])
  @@index([source])
  @@index([contentHash])
  @@index([location])
  @@index([firstSeen])
  @@index([canonicalJobId])
}

model JobVersion {
  id          String     @id @default(cuid())
  jobId       String
  contentHash String
  diff        Json?
  createdAt   DateTime   @default(now())
  job         JobPosting @relation("JobVersions", fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([contentHash])
}

model JobMatch {
  id              String     @id @default(cuid())
  userId          String
  resumeId        String?
  jobId           String
  overallScore    Float
  atsScore        Float?
  semanticScore   Float?
  skillsOverlap   Float?
  experienceMatch Float?
  freshnessScore  Float?
  matchedSkills   Json?
  missingSkills   Json?
  reasoning       String?
  createdAt       DateTime   @default(now())
  job             JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume          Resume?    @relation(fields: [resumeId], references: [id])
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId, resumeId])
  @@index([jobId])
  @@index([userId, overallScore(sort: Desc)])
}

model JobApplication {
  id          String     @id @default(cuid())
  userId      String
  jobId       String
  resumeId    String?
  status      String     @default("saved")
  appliedAt   DateTime?
  responseAt  DateTime?
  notes       String?
  coverLetter String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  job         JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  Resume      Resume?    @relation(fields: [resumeId], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

model SkillDemand {
  id               String   @id @default(cuid())
  skill            String   @unique
  demandCount      Int      @default(0)
  avgSalary        Int?
  growthRate       Float?
  category         String?
  updatedAt        DateTime
  demandPercentile Float?
  demandTrend      String?

  @@index([demandCount(sort: Desc)])
  @@index([category])
}
model CareerSite {
  id          String   @id @default(cuid())
  domain      String   @unique
  url         String
  label       String?
  source      String?  // e.g. "discovery", "manual"
  trustScore  Float    @default(0.5)
  lastScraped DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
  @@index([trustScore(sort: Desc)])
}

model DiscoverySource {
  id          String   @id @default(cuid())
  query       String   @unique
  frequency   String   @default("daily") // daily, weekly
  lastRun     DateTime?
  resultsFound Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lastRun])
}
